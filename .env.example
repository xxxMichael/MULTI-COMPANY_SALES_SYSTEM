# ===================================================================
# CONFIGURACIÓN DE EJEMPLO - Multi-company Sales System
# ===================================================================
# Copia este archivo como .env y ajusta los valores según tu entorno
# ===================================================================

# ========================= BASE DE DATOS =========================
# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sales_system_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password_aqui

# URL de conexión JDBC (se construye con las variables anteriores)
# O puedes usar directamente:
# DATABASE_URL=jdbc:postgresql://localhost:5432/sales_system_db

# ========================= SEGURIDAD JWT =========================
# Clave secreta para firmar tokens JWT (al menos 256 bits / 32 caracteres)
# Genera una clave segura con: openssl rand -base64 32
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura_aqui_minimo_32_caracteres

# Tiempo de expiración del token en milisegundos
# Por defecto: 86400000 = 24 horas
JWT_EXPIRATION=86400000

# ========================= ALMACENAMIENTO DE ARCHIVOS =========================
# Directorio para guardar imágenes de productos
# - En desarrollo local: usa ruta relativa como "uploads" o absoluta como "C:/productos"
# - En producción (Docker): usa "/app/uploads" (ya configurado en Dockerfile)
UPLOAD_DIR=uploads

# ========================= SERVIDOR =========================
# Puerto de la aplicación Spring Boot
SERVER_PORT=8080

# ========================= CORS (Opcional) =========================
# Orígenes permitidos para CORS (separados por coma)
# Si no se define, CorsConfig usa "*" por defecto
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ========================= ACTUATOR (Para Cloud) =========================
# Endpoints expuestos de Spring Actuator (health check para contenedores)
# Por defecto: health,info
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info

# ========================= PERFIL DE SPRING =========================
# Perfil activo de Spring Boot
# Valores: dev, prod, test
# SPRING_PROFILES_ACTIVE=dev

# ========================= HIBERNATE =========================
# Modo de actualización de esquema de base de datos
# Valores: none, validate, update, create, create-drop
# ⚠️ En producción usar "none" o "validate"
# SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Mostrar SQL en consola (true/false)
# SPRING_JPA_SHOW_SQL=false

# ========================= LOGGING =========================
# Nivel de logging
# Valores: TRACE, DEBUG, INFO, WARN, ERROR
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_MULTICOMPANY=DEBUG

# ========================= EMAIL (Opcional) =========================
# Configuración SMTP para envío de correos (si se implementa)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu_email@gmail.com
# MAIL_PASSWORD=tu_password_app_aqui
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS_ENABLE=true

# ========================= NOTAS =========================
# 1. NO subas el archivo .env al repositorio (ya está en .gitignore)
# 2. En Railway/DigitalOcean, configura estas variables en la UI
# 3. JWT_SECRET debe ser diferente en cada entorno (dev/prod)
# 4. En Docker Compose, estas variables se cargan automáticamente desde .env
